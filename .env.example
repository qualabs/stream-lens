# ── Google AI API ─────────────────────────────────────────────────────────────

# Required for the video analysis track.
# Also used for fusion when FUSION_MODEL has no ":" (Google model ID format).
GOOGLE_API_KEY=

# Gemma model for video frame analysis (Google API)
VIDEO_MODEL=gemma-4-26b-a4b-it

# Optional: replace the hardcoded video analysis instructions sent to the model.
# VIDEO_ANALYSIS_INSTRUCTIONS=

# ── Fusion model ──────────────────────────────────────────────────────────────

# Backend auto-detected from model ID:
#   Ollama  (ID contains ":"):  FUSION_MODEL=gemma4:e4b  or  smollm2:1.7b
#   Google API (no ":"):        FUSION_MODEL=gemma-4-26b-a4b-it
FUSION_MODEL=gemma4:e4b
FUSION_MODEL_TIMEOUT=300
OLLAMA_URL=http://ollama:11434/api/generate

# Prefix for all KV tags generated by the fusion model.
# All keys in the output string start with this prefix (e.g. ctx_activity=surfing).
FUSION_CONTEXT_PREFIX=ctx_

# Optional: replace the hardcoded fusion instructions sent to the model.
# FUSION_INSTRUCTIONS=

# ── Buffer / trigger ──────────────────────────────────────────────────────────

# BUFFER_SIZE: how many segments to feed into the analysis.
# ANALYSIS_TRIGGER_SEGMENTS: how many segments from the selected rendition to
#   receive before triggering analysis. Defaults to BUFFER_SIZE if unset.
BUFFER_SIZE=7
# ANALYSIS_TRIGGER_SEGMENTS=7

SEG_DURATION_S=2

# ── Rendition selection ───────────────────────────────────────────────────────

# Stream index of the video rendition to buffer for analysis.
# Must match the order defined by LIVE_SIM_RENDITIONS in live-sim:
#   LIVE_SIM_RENDITIONS=1920x1080:4000k,1280x720:2000k,854x480:1000k
#   → stream0=1080p  stream1=720p  stream2=480p
# Segments from all other renditions are forwarded to morpheus without buffering.
# Returns HTTP 503 on GET /context if this index is never seen in incoming segments.
ANALYSIS_VIDEO_RENDITION=2

# ── Frame extraction ──────────────────────────────────────────────────────────

FRAME_SAMPLE_MODE=iframes   # iframes (recommended) | fps
FRAME_SAMPLE_FPS=1.0        # used only when FRAME_SAMPLE_MODE=fps
MAX_FRAMES=15
FRAME_MAX_WIDTH=640

# ── Audio / transcription ─────────────────────────────────────────────────────

WHISPER_MODEL=medium        # tiny | medium | large-v3
WHISPER_DEVICE=cpu          # cpu | cuda

# ── Routing ───────────────────────────────────────────────────────────────────

MORPHEUS_BASE_URL=http://morpheus
# SERVER_PORT=8001
